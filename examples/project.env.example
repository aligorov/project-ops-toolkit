# shellcheck shell=bash

# Full profile example used by project_menu.sh, project_release.sh and remote_deploy.sh.

PROJECT_NAME="uos"

# Local release settings
ROOT_DIR="/absolute/path/to/local/repo"
RELEASE_REPO="aligorov/uos"
IMAGE_REPO="aligorov/uos"
VERSION_FILE="VERSION"
RELEASE_PACKAGE_JSONS=("package.json")
DOCKERFILE="Dockerfile"
BUILD_CONTEXT="."
PLATFORM="linux/amd64"
PUSH_LATEST="1"
RELEASE_GIT_ENABLED="1"
GIT_REMOTE="origin"
GIT_BRANCH="main"
GIT_TAG_PREFIX="v"
GIT_PROTOCOL="https"
GITHUB_OWNER="aligorov"
GITHUB_REPO_NAME="uos"
GITHUB_REPO_VISIBILITY="private"
GITHUB_REPO_DESCRIPTION="Universal project with Docker release/deploy toolkit"

# Deploy settings used on target host
REPO_URL="https://github.com/aligorov/uos.git"
APP_DIR="/opt/uos"
DEPLOY_REF="latest"
REF_TYPE="auto"
MAIN_BRANCH="main"
COMPOSE_DIR="."
COMPOSE_PROJECT_NAME="uos"
DEPLOY_COMPOSE_FILES=("docker-compose.yml")
DEPLOY_ENV_FILES=("/opt/project-ops/secrets/uos.deploy.env")
DEPLOY_SERVICES=("app")

# Remote server access
REMOTE_HOST="server.example.com"
REMOTE_USER="root"
REMOTE_PORT="22"
REMOTE_TOOLKIT_DIR="/opt/project-ops"
REMOTE_PROFILE_PATH="/opt/project-ops/profiles/uos.profile.env"
REMOTE_SECRETS_PATH="/opt/project-ops/secrets/uos.deploy.env"
REMOTE_SSH_KEY=""

# Local-only helpers
LOCAL_DEPLOY_SECRETS_FILE="/absolute/path/to/deploy/secrets/uos.deploy.env"
DEPLOY_ENV_TEMPLATE="/absolute/path/to/local/repo/.env.example"
